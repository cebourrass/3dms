<Window x:Class="Analyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vm="clr-namespace:Analyzer.ViewModels"
        mc:Ignorable="d"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="3DMS Pro Analyzer" Height="800" Width="1200"
        Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    
    <Grid>
        <ui:NavigationView x:Name="NavView" 
                          IsSettingsVisible="True"
                          PaneDisplayMode="Left"
                          IsBackButtonVisible="Collapsed">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard" Icon="Library" />
                <ui:NavigationViewItem Content="Télémétrie" Icon="FourBars" />
                <ui:NavigationViewItem Content="Carte &amp; Tours" Icon="Map" />
                <ui:NavigationViewItem Content="Statistiques" Icon="PostUpdate" />
            </ui:NavigationView.MenuItems>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Lédenon - 12/04/2026" Style="{StaticResource HeaderTextBlockStyle}" Foreground="{DynamicResource SystemControlHighlightAccentBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Background="#007acc" CornerRadius="10" Padding="8,2" Margin="0,0,12,0">
                            <TextBlock Text="01:50.96" Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Meilleur Tour Personnel" VerticalAlignment="Center" Opacity="0.7"/>
                    </StackPanel>
                </StackPanel>

                <!-- Content Area -->
                <UniformGrid Grid.Row="1" Columns="2">
                    <!-- Telemetry Chart -->
                    <Border Margin="0,0,12,0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="#333">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Vitesse et Angle d'inclinaison" Margin="12" FontWeight="Bold" Opacity="0.7"/>
                            
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding SpeedSeries}" XAxes="{Binding XAxes}" Margin="10"/>
                            <lvc:CartesianChart Grid.Row="2" Series="{Binding AngleSeries}" XAxes="{Binding XAxes}" Margin="10"/>
                        </Grid>
                    </Border>
                    
                    <!-- Map Placeholder -->
                    <Border Margin="12,0,0,0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="#333" ClipToBounds="True">
                        <Grid>
                            <Image Source="https://www.google.com/maps/vt/pb=!1m4!1m3!1i15!2i16447!3i11808!2m3!1e0!2sm!3i637156903!3m8!2sfr!3sp!5e1105!12m4!1e68!2m2!1sset!2sRoadmap!4e0!5m1!1sfsy:1" Stretch="UniformToFill" Opacity="0.3"/>
                            <TextBlock Text="Vue Map Satellite (En attente de données GPS)" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White" Opacity="0.5"/>
                            
                            <!-- Overlay Trajectory mockup -->
                            <Polyline Points="50,150 100,100 150,120 200,80 250,200" Stroke="Cyan" StrokeThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </UniformGrid>
            </Grid>
        </ui:NavigationView>
    </Grid>
</Window>
